# Copy to deploy/.env and adjust paths for your machine.
# Usage: docker compose -f deploy/docker-compose.yml --env-file deploy/.env up --build

# Host directory bind-mounted as /data/archive in every data-plane service.
LUMA_ARCHIVE_HOST_PATH=../Livehouse_Archive

# Optional: point gallery at a specific session previews folder inside the archive.
# LIVEHOUSE_GALLERY_PREVIEWS_DIR=/data/archive/2026-04-26/Previews

# Ollama on the host (Mac/Windows Docker Desktop). Linux without host.docker.internal: use compose profile ollama.
OLLAMA_HOST=http://host.docker.internal:11434

# SD ingest profile (optional): real card mount, e.g. /Volumes/NO_NAME
# SD_MOUNT=/Volumes/YOUR_SD_CARD
# DEVICE_ID=camera_a

# LIVEHOUSE_INGEST_TOKEN=

FASTAPI_PORT=8080
NEXT_PORT=3000
