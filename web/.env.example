# --- Live Lab on http://localhost:3000 ---
# Leave empty → browser calls /api/* and /image on :3000; Next proxies to FastAPI (GALLERY_API_ORIGIN / next.config.js).
# Uncomment only if you intentionally want cross-origin requests to FastAPI:
# NEXT_PUBLIC_API_BASE=http://127.0.0.1:8080

# Server-side rewrite target when running `pnpm dev` (no NEXT_ prefix → not inlined in bundle):
GALLERY_API_ORIGIN=http://127.0.0.1:8080

# Public landing deploy (Vercel): set LANDING_ONLY=1 so Next does not proxy /api/* to localhost.
# Bundled photos: `python scripts/build_demo_gallery.py --src /path/to/selects --count 12`
# then commit web/public/demo/ and web/lib/demoGallery.json.
# LANDING_ONLY=1

# Archive root for Studio sessions (the "set list" on /studio). Required for the filesystem
# session scan; without it studio_cli falls back to the configs/livehouse.yaml placeholder path
# and the set list shows almost nothing. Set your real path in web/.env.local (gitignored).
# LUMA_ARCHIVE_ROOT=/path/to/your/Livehouse_Archive

